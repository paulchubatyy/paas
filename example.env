# ============================================================
# COMPOSE FILE CONFIGURATION
# ============================================================
# Pick your services (colon-separated). Swap postgres for mariadb to switch DB.
COMPOSE_FILE=compose/traefik.yml:compose/postgres.yml:compose/valkey.yml
# COMPOSE_FILE=compose/traefik.yml:compose/mariadb.yml:compose/valkey.yml

# ============================================================
# POSTGRESQL (when using compose/postgres.yml)
# ============================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=postgres

# ============================================================
# MARIADB (when using compose/mariadb.yml)
# ============================================================
# MYSQL_ROOT_PASSWORD=changeme_root
# MYSQL_USER=mariadb
# MYSQL_PASSWORD=changeme
# MYSQL_DATABASE=app

# ============================================================
# S3 BACKUP CONFIGURATION
# ============================================================
# Uncomment ONE provider section below and configure the values
# All providers use these common settings
S3_PREFIX=paas/db                     # Folder path in bucket
SCHEDULE=@daily                       # @daily, @hourly, @weekly, or @monthly
ENCRYPTION_PASSWORD=optional_encryption_key  # Optional: encrypt backups
BACKUP_ALL=true                       # Set to "true" to backup all databases
EXTRA_OPTS=                           # Additional dump options (pg_dump or mysqldump)
DROP_PUBLIC=yes                       # Restore: drops public schema (PG) or recreates DB (MariaDB)

# --------------------------
# AWS S3
# --------------------------
# Required: Create bucket in AWS S3 console
# https://aws.amazon.com/s3/
# S3_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# S3_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# S3_BUCKET=my-backup-bucket
# S3_REGION=us-east-1

# --------------------------
# Cloudflare R2
# --------------------------
# Required: Create R2 bucket in Cloudflare dashboard
# https://developers.cloudflare.com/r2/
# S3_ACCESS_KEY_ID=your_r2_access_key
# S3_SECRET_ACCESS_KEY=your_r2_secret_key
# S3_BUCKET=my-r2-backup-bucket
# S3_REGION=auto
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# --------------------------
# DigitalOcean Spaces
# --------------------------
# Required: Create Space in DO dashboard
# https://docs.digitalocean.com/products/spaces/
# S3_ACCESS_KEY_ID=your_do_access_key
# S3_SECRET_ACCESS_KEY=your_do_secret_key
# S3_BUCKET=my-backup-space
# S3_REGION=nyc3  # nyc3, sfo2, ams3, sgp1, fra1, syd1
# S3_ENDPOINT=https://nyc3.digitaloceanspaces.com

# --------------------------
# Backblaze B2
# --------------------------
# Required: Create bucket in B2, then use B2 CLI to get S3 keys
# https://www.backblaze.com/b2/cloud-storage.html
# S3_ACCESS_KEY_ID=your_b2_key_id
# S3_SECRET_ACCESS_KEY=your_b2_application_key
# S3_BUCKET=my-backup-bucket
# S3_REGION=us-west-004  # or your bucket's region
# S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com

# --------------------------
# Wasabi
# --------------------------
# Required: Create bucket in Wasabi console
# https://wasabi.com/
# S3_ACCESS_KEY_ID=your_wasabi_access_key
# S3_SECRET_ACCESS_KEY=your_wasabi_secret_key
# S3_BUCKET=my-backup-bucket
# S3_REGION=us-east-1  # Wasabi region names
# S3_ENDPOINT=https://s3.wasabisys.com

# --------------------------
# MinIO (Self-Hosted)
# --------------------------
# Required: Deploy your own MinIO server
# https://min.io/
# S3_ACCESS_KEY_ID=your_minio_access_key
# S3_SECRET_ACCESS_KEY=your_minio_secret_key
# S3_BUCKET=my-backup-bucket
# S3_REGION=us-east-1
# S3_ENDPOINT=https://minio.yourdomain.com
