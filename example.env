# ============================================================
# SERVICES
# ============================================================
# Which compose files to load (colon-separated).
# To switch databases, swap postgres.yml for mariadb.yml.
COMPOSE_FILE=compose/traefik.yml:compose/postgres.yml:compose/valkey.yml
# COMPOSE_FILE=compose/traefik.yml:compose/mariadb.yml:compose/valkey.yml

# ============================================================
# ADMIN DASHBOARD
# ============================================================
# Traefik dashboard hostname — point this DNS record to your server first.
# ADMIN_HOSTNAME=admin.example.com

# Let's Encrypt needs a valid email to issue SSL certificates.
# ADMIN_EMAIL=you@example.com

# HTTP basic auth for the dashboard. Generate with:
#   make gen-admin-auth USER=admin PASS=secret >> .env
# or the install script sets this automatically.
# ADMIN_CREDENTIALS=admin:$2y$05$...

# ============================================================
# POSTGRESQL (used when compose/postgres.yml is in COMPOSE_FILE)
# ============================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=postgres

# ============================================================
# MARIADB (used when compose/mariadb.yml is in COMPOSE_FILE)
# ============================================================
# Uncomment these when using MariaDB. The install script handles this automatically.
# Root password is required by MariaDB in addition to the app user.
# MYSQL_ROOT_PASSWORD=
# MYSQL_USER=mariadb
# MYSQL_PASSWORD=
# MYSQL_DATABASE=app

# ============================================================
# BACKUPS — Common settings
# ============================================================
# Backups run on a schedule and upload to any S3-compatible storage.
# Nothing happens until you configure an S3 provider below.

# Folder path inside your S3 bucket.
S3_PREFIX=paas/db

# How often to back up: @hourly, @daily, @weekly, @monthly, @yearly
SCHEDULE=@daily

# Leave empty for unencrypted backups. Set a passphrase to AES-256 encrypt.
ENCRYPTION_PASSWORD=

# true = dump all databases in one file. false = dump only the DB named above.
BACKUP_ALL=true

# Extra flags passed to pg_dump or mysqldump (usually leave empty).
EXTRA_OPTS=

# On restore: drop existing data before loading the backup.
# PostgreSQL: drops the public schema. MariaDB: drops and recreates the database.
DROP_PUBLIC=yes

# ============================================================
# BACKUPS — S3 provider (uncomment ONE section)
# ============================================================

# --- AWS S3 ---
# Create a bucket: https://aws.amazon.com/s3/
# Create an IAM user with S3 access and generate access keys.
# S3_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# S3_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# S3_BUCKET=my-backup-bucket
# S3_REGION=us-east-1

# --- Cloudflare R2 ---
# Create a bucket: https://developers.cloudflare.com/r2/
# Generate API token with R2 read/write permissions.
# S3_ACCESS_KEY_ID=your_r2_access_key
# S3_SECRET_ACCESS_KEY=your_r2_secret_key
# S3_BUCKET=my-r2-backup-bucket
# S3_REGION=auto
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# --- DigitalOcean Spaces ---
# Create a Space: https://docs.digitalocean.com/products/spaces/
# Generate Spaces access keys in API settings.
# S3_ACCESS_KEY_ID=your_do_access_key
# S3_SECRET_ACCESS_KEY=your_do_secret_key
# S3_BUCKET=my-backup-space
# S3_REGION=nyc3
# S3_ENDPOINT=https://nyc3.digitaloceanspaces.com

# --- Backblaze B2 ---
# Create a bucket, then generate an application key with S3 compatibility.
# https://www.backblaze.com/b2/cloud-storage.html
# S3_ACCESS_KEY_ID=your_b2_key_id
# S3_SECRET_ACCESS_KEY=your_b2_application_key
# S3_BUCKET=my-backup-bucket
# S3_REGION=us-west-004
# S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com

# --- Wasabi ---
# Create a bucket: https://wasabi.com/
# Generate access keys in your Wasabi console.
# S3_ACCESS_KEY_ID=your_wasabi_access_key
# S3_SECRET_ACCESS_KEY=your_wasabi_secret_key
# S3_BUCKET=my-backup-bucket
# S3_REGION=us-east-1
# S3_ENDPOINT=https://s3.wasabisys.com

# --- MinIO (self-hosted) ---
# Deploy MinIO: https://min.io/
# Use the access/secret key from your MinIO instance.
# S3_ACCESS_KEY_ID=your_minio_access_key
# S3_SECRET_ACCESS_KEY=your_minio_secret_key
# S3_BUCKET=my-backup-bucket
# S3_REGION=us-east-1
# S3_ENDPOINT=https://minio.yourdomain.com
